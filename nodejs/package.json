{
  "name": "jrspc-node-raw-sql",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "JRSPC modular MVC Node.js backend — raw SQL with mysql2 (no Prisma)",
  "imports": {
    "#app": "./src/app.js",
    "#config/*": "./src/config/*.js",
    "#shared/*": "./src/shared/*.js",
    "#modules/*": "./src/modules/*.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "postinstall": "npx puppeteer browsers install chrome",
    "install:chrome": "npx puppeteer browsers install chrome",
    "migrate": "node scripts/migrate.js",
    "migrate:v2": "node scripts/migrate-v2.js",
    "create:platform-admin": "node scripts/create-platform-admin.js",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "node-cron": "^4.0.7",
    "pdfkit": "^0.18.0",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.42.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^4.1.5"
  }
}
